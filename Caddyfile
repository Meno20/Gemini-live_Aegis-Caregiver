# Caddy configuration for Cloud Run
{
    admin off
    persist_config off
}

:{$PORT:8080} {
    # WebSocket endpoint
    handle /ws* {
        reverse_proxy localhost:8081 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Next.js application
    handle {
        reverse_proxy localhost:3001
    }
}
