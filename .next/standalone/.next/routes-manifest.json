{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/patient/[id]",
      "regex": "^/patient/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/patient/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api",
      "regex": "^/api(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api(?:/)?$"
    },
    {
      "page": "/api/alerts",
      "regex": "^/api/alerts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/alerts(?:/)?$"
    },
    {
      "page": "/api/analysis",
      "regex": "^/api/analysis(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/analysis(?:/)?$"
    },
    {
      "page": "/api/asr",
      "regex": "^/api/asr(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/asr(?:/)?$"
    },
    {
      "page": "/api/auth/login",
      "regex": "^/api/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/login(?:/)?$"
    },
    {
      "page": "/api/auth/logout",
      "regex": "^/api/auth/logout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/logout(?:/)?$"
    },
    {
      "page": "/api/cron/nightly",
      "regex": "^/api/cron/nightly(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/cron/nightly(?:/)?$"
    },
    {
      "page": "/api/insights",
      "regex": "^/api/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/insights(?:/)?$"
    },
    {
      "page": "/api/interactions",
      "regex": "^/api/interactions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/interactions(?:/)?$"
    },
    {
      "page": "/api/patients",
      "regex": "^/api/patients(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/patients(?:/)?$"
    },
    {
      "page": "/api/reports",
      "regex": "^/api/reports(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/reports(?:/)?$"
    },
    {
      "page": "/api/tts",
      "regex": "^/api/tts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/tts(?:/)?$"
    },
    {
      "page": "/api/video/signaling",
      "regex": "^/api/video/signaling(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/video/signaling(?:/)?$"
    },
    {
      "page": "/api/vision",
      "regex": "^/api/vision(?:/)?$",
      "routeKeys": {},
